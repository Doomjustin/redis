{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Scaffold: C++ (快速: xin/redis)",
            "type": "shell",
            "command": "bash",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "${workspaceFolder}/.vscode/scripts/scaffold_cpp.sh",
                "${input:fileBaseQuick}",
                "xin/redis",
                "${workspaceFolder}",
                ""
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "showReuseMessage": false,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            "label": "Scaffold: C++ (高级: 自定义目录/命名空间)",
            "type": "shell",
            "command": "bash",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "${workspaceFolder}/.vscode/scripts/scaffold_cpp.sh",
                "${input:fileBaseAdvanced}",
                "${input:targetDirPick}",
                "${workspaceFolder}",
                "${input:namespacePick}"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "showReuseMessage": false,
                "echo": false
            },
            "problemMatcher": []
        },
        {
            "label": "Scaffold: C++ (手动输入: 任意路径)",
            "type": "shell",
            "command": "bash",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "${workspaceFolder}/.vscode/scripts/scaffold_cpp.sh",
                "${input:fileBaseManual}",
                "${input:targetDirManual}",
                "${workspaceFolder}",
                "${input:namespaceManual}"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "showReuseMessage": false,
                "echo": false
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "fileBaseQuick",
            "type": "promptString",
            "description": "快速模式: 输入文件基名（例如 redis_bitmap）"
        },
        {
            "id": "fileBaseAdvanced",
            "type": "promptString",
            "description": "高级模式: 输入文件基名（例如 redis_bitmap）"
        },
        {
            "id": "targetDirPick",
            "type": "pickString",
            "description": "选择生成目录",
            "default": "xin/redis",
            "options": [
                "xin/redis",
                "xin/base",
                "xin"
            ]
        },
        {
            "id": "namespacePick",
            "type": "pickString",
            "description": "选择命名空间（空值表示按目录自动推导）",
            "default": "",
            "options": [
                "",
                "xin::redis",
                "xin::base",
                "xin"
            ]
        },
        {
            "id": "fileBaseManual",
            "type": "promptString",
            "description": "手动模式: 输入文件基名（例如 redis_bitmap）"
        },
        {
            "id": "targetDirManual",
            "type": "promptString",
            "description": "手动模式: 输入生成目录（支持绝对路径）",
            "default": "xin/redis"
        },
        {
            "id": "namespaceManual",
            "type": "promptString",
            "description": "手动模式: 输入命名空间（留空按目录自动推导）",
            "default": ""
        }
    ]
}